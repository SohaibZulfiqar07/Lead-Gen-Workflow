        "jsCode": "// Get all source_urls already stored in Leads sheet\nconst existingUrls = new Set(\n  $('Read Existing Leads').all().map(i => i.json.source_url).filter(Boolean)\n);\n\n// Filter out any lead already in the sheet\nreturn items.filter(item => {\n  const url = item.json.source_url;\n  return url && !existingUrls.has(url);\n});"
      },
